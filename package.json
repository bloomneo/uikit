    "dist",
    "bin",
    "examples",
    "cookbook",
    "skills",
    "llms.txt",
    "AGENTS.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run clean && npm run build:lib && npm run build:css && npm run build:fonts && npm run build:types && npm run build:llms",
    "build:llms": "node scripts/build-llms.mjs",
    "build:lib": "vite build",
    "build:css": "node scripts/build-styles.mjs",
    "build:fonts": "cp -r src/fonts dist/",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "clean": "rm -rf dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "test": "npm run check:docs && npm run check:anchors && vitest --run",
    "test:unit": "vitest --run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --run",
    "check:docs": "npx tsx scripts/check-doc-drift.ts",
    "check:anchors": "npx tsx scripts/check-readme-anchors.ts",
    "deploy": "gh-pages -d docs/dist",
    "prepublishOnly": "npm run test && npm run build",
    "preversion": "npm run build",
    "postversion": "git push && git push --tags"
  },
